# GNS3 MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: GNS3 Server URL (include port if not 80/443)
GNS3_URL=http://localhost:3080

# Required: GNS3 authentication credentials
GNS3_USER=admin
GNS3_PASSWORD=your_password_here

# Optional: SSL certificate verification (default: true)
GNS3_VERIFY_SSL=true

# Optional: Token cache TTL in seconds (default: 3000 = 50 minutes)
GNS3_TOKEN_TTL=3000
