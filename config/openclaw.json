        "mcp-servers/checkpoint-mcp-servers/packages/harmony-sase/dist/index.js"
      ],
      "env": {
        "API_KEY": "${CHKP_SASE_API_KEY}",
        "MANAGEMENT_HOST": "${CHKP_SASE_MGMT_HOST}",
        "ORIGIN": "${CHKP_SASE_ORIGIN}",
        "TELEMETRY_DISABLED": "${CHKP_TELEMETRY_DISABLED:-true}"
      }
    },
    "chkp-reputation-service": {
      "command": "node",
      "args": [
        "mcp-servers/checkpoint-mcp-servers/packages/reputation-service/dist/index.js"
      ],
      "env": {
        "API_KEY": "${CHKP_REPUTATION_API_KEY}",
        "TELEMETRY_DISABLED": "${CHKP_TELEMETRY_DISABLED:-true}"
      }
    },
    "chkp-quantum-gw-cli": {
      "command": "node",
      "args": [
        "mcp-servers/checkpoint-mcp-servers/packages/gw-cli/dist/index.js"
      ],
      "env": {
        "MANAGEMENT_HOST": "${CHKP_MGMT_HOST}",
        "PORT": "${CHKP_MGMT_PORT:-443}",
        "API_KEY": "${CHKP_MGMT_API_KEY}",
        "USERNAME": "${CHKP_MGMT_USERNAME}",
        "PASSWORD": "${CHKP_MGMT_PASSWORD}",
        "DOMAIN": "${CHKP_MGMT_DOMAIN}",
        "TELEMETRY_DISABLED": "${CHKP_TELEMETRY_DISABLED:-true}"
      }
    },
    "chkp-gw-connection-analysis": {
      "command": "node",
      "args": [
        "mcp-servers/checkpoint-mcp-servers/packages/gw-cli-connection-analysis/dist/index.js"
      ],
      "env": {
        "MANAGEMENT_HOST": "${CHKP_MGMT_HOST}",
        "PORT": "${CHKP_MGMT_PORT:-443}",
        "API_KEY": "${CHKP_MGMT_API_KEY}",
        "USERNAME": "${CHKP_MGMT_USERNAME}",
